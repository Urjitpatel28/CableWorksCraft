<Window x:Class="WpfUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfUI.ViewModels"
        xmlns:views="clr-namespace:WpfUI.Views"
        xmlns:vm="clr-namespace:WpfUI.ViewModels"
        mc:Ignorable="d"
        ResizeMode="CanMinimize"
        Title="{Binding ApplicationVersion}" Height="{Binding WindowHeight, Mode=TwoWay}" Width="1300"  WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/WpfUI;component/Resources/Untitled.png">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    
    <Grid>       
        <views:CableDetailUC 
        DataContext="{Binding}"
        x:Name="CableDetailUC" 
        Visibility="Visible"/>
    </Grid>
</Window>