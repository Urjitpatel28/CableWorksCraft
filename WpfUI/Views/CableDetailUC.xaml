<UserControl x:Class="WpfUI.Views.CableDetailUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:WpfUI.ViewModels" 
             xmlns:cv ="clr-namespace:WpfUI.Helpers"             
             mc:Ignorable="d" Width="1280">
    <UserControl.DataContext>
        <vm:MainViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <cv:BoolNegationConverter x:Key="BoolNegationConverter"/>
        <cv:LayerVisibilityConverter x:Key="LayerVisibilityConverter"/>
        <cv:FillingMethodToBoolConverter x:Key="FillingMethodConverter"/>
        <cv:DecimalValueConverter x:Key="DecimalValueConverter"/>
        <cv:EnabledToTextConverter x:Key="EnabledToTextConverter"/>
        <cv:CoreTypeToVisibilityConverter x:Key="CoreTypeVisibilityConverter"/>
        <cv:CoreTypeToVisibilityConverter2 x:Key="CoreTypeVisibilityConverter2"/>
        <cv:CeilingGreaterOrEqualConverter x:Key="CeilingGreaterOrEqualConverter"/>
        <cv:CeilingLessOrEqualConverter x:Key="CeilingLessOrEqualConverter"/>
    </UserControl.Resources>

    <Border Padding="9">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!--<StackPanel Orientation="Horizontal">
                <Button Width="30" Height="30" HorizontalAlignment="Left" VerticalAlignment="Top" ToolTip="Back">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border BorderThickness="1" CornerRadius="15">
                                <Canvas>
                                    <Path Data="M0,10 L10,5 L10,8 L20,8 L20,12 L10,12 L10,15 Z" Fill="#FF000000" Width="20" Height="15" Canvas.Left="5" Canvas.Top="7" Stretch="Fill"/>
                                </Canvas>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Back" VerticalAlignment="Center" Foreground="DimGray"/>
            </StackPanel>-->

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!--Cable detail panel-->

                <Border BorderBrush="Gray" Grid.Row="1" BorderThickness="1" Padding="1">
                    <StackPanel>
                        <StackPanel Margin="10">
                            <GroupBox Header="Project Detail">
                                <Grid HorizontalAlignment="Left" Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <!--Project Name-->
                                    <TextBlock Text="Project Name :" Margin="10" Grid.Row="0" Grid.Column="0"/>
                                    <TextBox x:Name="ProjectNameText" 
                                         Text="{Binding ProjectDetails.projectName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                         Width="Auto" Margin="10 7" Grid.Row="0" Grid.Column="1" VerticalContentAlignment="Center"/>

                                    <!--Core Type-->
                                    <TextBlock Text="Cable Core Type :" Margin="10" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="CableCoreTypesComboBox"
                                              ItemsSource="{Binding CableCoreTypes}"
                                              SelectedItem="{Binding SelectedCableCoreType, UpdateSourceTrigger=PropertyChanged}"
                                              Width="Auto" Margin="10" Grid.Row="1" Grid.Column="1"/>
                                    <!--Number of Cores-->
                                    <TextBlock Text="Number of Cores :" Margin="10" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="NoOfCoreComboBox" SelectionChanged="NumLayersComboBox_SelectionChanged"
                                              ItemsSource="{Binding NumberOfCores}"
                                              SelectedValue="{Binding ProjectDetails.parameters.numCylindersPerLayer, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="."
                                              SelectedValuePath="."
                                              Width="Auto" Margin="10" Grid.Row="2" Grid.Column="1"
                                              >
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCableCoreType}" Value="Circular">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedCableCoreType}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>

                                    <TextBox x:Name="NoOfCoreSectoralComboBox" TextChanged="NumLayersComboBox_TextChanged"
                                            Width="Auto" Margin="10" Grid.Row="2" Grid.Column="1" VerticalContentAlignment="Center">
                                        <TextBox.Text>
                                            <Binding Path="ProjectDetails.parameters.numCylindersPerLayer"
                                                    UpdateSourceTrigger="PropertyChanged"
                                                     Delay="1000">
                                                <Binding.ValidationRules>
                                                    <cv:HalfMultiplierValidationRule ValidatesOnTargetUpdated="True" />
                                                </Binding.ValidationRules>
                                            </Binding>
                                        </TextBox.Text>
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Validation.ErrorTemplate">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <DockPanel LastChildFill="True">
                                                                <TextBlock DockPanel.Dock="Bottom" Foreground="Red" FontSize="12"
                                       Text="{Binding ElementName=customAdorner, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"/>
                                                                <Border BorderBrush="Red" BorderThickness="1" Margin="0">
                                                                    <AdornedElementPlaceholder Name="customAdorner"/>
                                                                </Border>
                                                            </DockPanel>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCableCoreType}" Value="Shaped">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedCableCoreType}" Value="Circular">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <Button Content="Create Project" 
                                            Command="{Binding CreateProjectCommand}"                                     
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center" 
                                            HorizontalAlignment="Center"
                                            Height ="22" Width="120"
                                            Margin="10"
                                            Grid.Column="2" Grid.Row="2"/>
                                </Grid>
                            </GroupBox>
                        </StackPanel>

                        <StackPanel IsEnabled="{Binding CableInfoPanelEnabled}">
                            <!--Wire dia-->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Wire Dia [mm] :" Margin="10 5 5 5"/>
                                    <TextBox x:Name="WireRadius"
                                         Text="{Binding ProjectDetails.parameters.wire_dia,ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                         Width="150" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </StackPanel>


                            </Grid>

                            <!--Conductor-->
                            <GroupBox Visibility="{Binding SelectedCableCoreType, Converter={StaticResource CoreTypeVisibilityConverter}}">
                                <GroupBox.Header>
                                    <CheckBox Content="Conductor" IsEnabled="False" IsChecked="True"/>
                                </GroupBox.Header>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250"/>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                            <TextBlock Text="Conductor Dia [mm] :" VerticalAlignment="Center"/>
                                            <TextBox x:Name="ConductorDiaTextBox" 
                                                 Text="{Binding ProjectDetails.parameters.ConductorDia,UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                 Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="ConductorMaterialList" 
                                                  ItemsSource="{Binding ConductorMaterialList}"
                                                  Margin="10 0 0 0" Width="100" VerticalContentAlignment="Center"
                                                  SelectedValue="{Binding ProjectDetails.parameters.conductorMaterial}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="2" VerticalAlignment="Center" Visibility="Hidden">
                                            <TextBlock Text="Conductor Color : " Margin="5" VerticalAlignment="Center"/>
                                            <ComboBox 
                                                      ItemsSource="{Binding ColorList}"
                                                      Width="80" Margin="5"
                                                      SelectedValue="{Binding ProjectDetails.parameters.conductorScreenColor, Mode=OneWayToSource}"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    
                                    <!--half core dia-->
                                    <Grid Grid.Column="1" Visibility="{Binding SelectedCableCoreType, Converter={StaticResource CoreTypeVisibilityConverter}}">
                                        <Grid.IsEnabled>
                                            <Binding Path="ProjectDetails.parameters.numCylindersPerLayer" Converter="{StaticResource DecimalValueConverter}"/>
                                        </Grid.IsEnabled>
                                        <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                            <TextBlock Text="Half Core Dia [mm] :" VerticalAlignment="Center"/>
                                            <TextBox x:Name="halfcore_radiusTex" 
                                                 Text="{Binding ProjectDetails.parameters.halfcore_dia, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=1000}"
                                                 Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            
                            <!--for shaped-->
                            <GroupBox Visibility="{Binding SelectedCableCoreType, Converter={StaticResource CoreTypeVisibilityConverter2}}">
                                <GroupBox.Header>
                                    <CheckBox Content="Core" IsEnabled="False" IsChecked="True"/>
                                </GroupBox.Header>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250"/>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                            <TextBlock Text="Layyd Dia [mm] :" VerticalAlignment="Center"/>
                                            <TextBox 
                                                 Text="{Binding ProjectDetails.parameters.layyd_dia,UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                 Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                            <ComboBox 
                                                  ItemsSource="{Binding ConductorMaterialList}"
                                                  Margin="10 0 0 0" Width="100" VerticalContentAlignment="Center"
                                                  SelectedValue="{Binding ProjectDetails.parameters.conductorMaterial}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10 5 " Grid.Column="2" VerticalAlignment="Center" Visibility="Hidden">
                                            <TextBlock Text="Core Color : " Margin="5" VerticalAlignment="Center"/>
                                            <ComboBox 
                                                      ItemsSource="{Binding ColorList}"
                                                      Width="80" Margin="5"
                                                      SelectedValue="{Binding ProjectDetails.parameters.conductorScreenColor, Mode=OneWayToSource}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!--half core dia-->
                                    <Grid Grid.Column="1" Visibility="{Binding SelectedCableCoreType, Converter={StaticResource CoreTypeVisibilityConverter}}">
                                        <Grid.IsEnabled>
                                            <Binding Path="ProjectDetails.parameters.numCylindersPerLayer" Converter="{StaticResource DecimalValueConverter}"/>
                                        </Grid.IsEnabled>
                                        <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                            <TextBlock Text="Half Core Dia [mm] :" VerticalAlignment="Center"/>
                                            <TextBox  
                                                 Text="{Binding ProjectDetails.parameters.halfcore_dia, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=1000}"
                                                 Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>
                            
                            <!--Insulation-->
                            <GroupBox>
                                <GroupBox.Header>
                                    <CheckBox Content="Insulation" IsChecked="{Binding IsInsulationEnabled, Mode=TwoWay}"/>
                                </GroupBox.Header>
                                <Grid IsEnabled="{Binding IsInsulationEnabled}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                        <TextBlock Text="Insulation Thickness [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="InsulationThkTextBox" 
                                                  Text="{Binding ProjectDetails.parameters.spacing_2, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=1000}"
                                                 Margin="10 0 0 0" Width="80" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="InsulationMaterialList"
                                                  ItemsSource="{Binding InsulationMaterialList}"
                                                  SelectedItem="{Binding ProjectDetails.parameters.insulationMaterial}"
                                                  Margin="10 0 0 0" Width="100" VerticalContentAlignment="Center"
                                                 />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="2" VerticalAlignment="Center" Visibility="Hidden">
                                        <TextBlock Text="Insulation Color : " Margin="5" VerticalAlignment="Center"/>
                                        <ComboBox 
                                              ItemsSource="{Binding ColorList}"
                                              Width="90" Margin="5 0 0 0"
                                              SelectedValue="{Binding ProjectDetails.parameters.insulationColor, Mode=OneWayToSource}"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <!--Conductor Screen-->
                            <GroupBox>
                                <GroupBox.Header>
                                    <CheckBox Content="Conductor Screen"  IsChecked="{Binding IsConductorScreenEnabled, Mode=TwoWay}"  Unchecked="ConductorScreenCheckBox_Unchecked"/>
                                </GroupBox.Header>
                                <StackPanel IsEnabled="{Binding IsConductorScreenEnabled}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                            <TextBlock Text="Number of layers :" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="NoOfLayersList" 
                                                      ItemsSource="{Binding NoOfLayersList}" 
                                                      DisplayMemberPath="."
                                                      SelectedValuePath="."
                                                      SelectedValue="{Binding SelectedNumberOfLayers, Mode=TwoWay}"
                                                      Margin="10 0 0 0" Width="100" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <GroupBox Header="Layer 1" IsEnabled="{Binding SelectedNumberOfLayers, Converter={StaticResource LayerVisibilityConverter}, ConverterParameter=1}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="250"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="220"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                                <TextBlock Text="Layer 1 Thickness [mm] :" VerticalAlignment="Center"/>
                                                <TextBox x:Name="Layer1ThicknessTextBox" 
                                                         Text="{Binding ProjectDetails.parameters.spacing_3, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                         Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                                <ComboBox x:Name="Layer1MaterialComboBox" 
                                                          ItemsSource="{Binding ConductorScreenMaterialList}"                                                  
                                                          Margin="10 0 0 0" Width="100" VerticalContentAlignment="Center"
                                                          SelectedValue="{Binding ProjectDetails.parameters.layer_1Material}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="Color : " Margin="5" VerticalAlignment="Center"/>
                                                <ComboBox x:Name="ColorLayer1"
                                                            ItemsSource="{Binding LayerColorList}"
                                                            Width="90" Margin="0"
                                                            SelectedValue="{Binding ProjectDetails.parameters.insulationColor, Mode=OneWayToSource}"/>
                                            </StackPanel>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="Layer 2" IsEnabled="{Binding SelectedNumberOfLayers, Converter={StaticResource LayerVisibilityConverter}, ConverterParameter=2}"
                                              Visibility="{Binding SelectedCableCoreType, Converter={StaticResource CoreTypeVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="250"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="220"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                                <TextBlock Text="Layer 2 Thickness [mm] :" VerticalAlignment="Center"/>
                                                <TextBox x:Name="Layer2Text" 
                                                         Text="{Binding ProjectDetails.parameters.spacing_4, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                         Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                                <ComboBox x:Name="Layer2MaterialComboBox"
                                                          ItemsSource="{Binding ConductorScreenMaterialList}"
                                                          Margin="10 0 0 0" Width="100" VerticalContentAlignment="Center"
                                                          SelectedValue="{Binding ProjectDetails.parameters.layer_2Material}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="Color : " Margin="5" VerticalAlignment="Center"/>
                                                <ComboBox  x:Name="ColorLayer2"
                                                            ItemsSource="{Binding LayerColorList}"
                                                            Width="90" Margin="0"
                                                            SelectedValue="{Binding ProjectDetails.parameters.nometallicScreenColor, Mode=OneWayToSource}"/>
                                            </StackPanel>
                                        </Grid>
                                    </GroupBox>

                                    <GroupBox Header="Layer 3" IsEnabled="{Binding SelectedNumberOfLayers, Converter={StaticResource LayerVisibilityConverter}, ConverterParameter=3}" 
                                              Visibility="{Binding SelectedCableCoreType, Converter={StaticResource CoreTypeVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="250"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="220"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                                <TextBlock Text="Layer 3 Thickness [mm] :" VerticalAlignment="Center"/>
                                                <TextBox x:Name="Layer3Text" 
                                                         Text="{Binding ProjectDetails.parameters.spacing_5, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                         Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                                <ComboBox x:Name="Layer3MaterialComboBox" 
                                                          ItemsSource="{Binding ConductorScreenMaterialList}"
                                                          Margin="10 0 0 0" Width="100" VerticalContentAlignment="Center"
                                                          SelectedValue="{Binding ProjectDetails.parameters.layer_3Material}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="Color : " Margin="5" VerticalAlignment="Center"/>
                                                <ComboBox  x:Name="ColorLayer3"
                                                            ItemsSource="{Binding LayerColorList}"
                                                            Width="90" Margin="0"
                                                            SelectedValue="{Binding ProjectDetails.parameters.metallicScreenColor, Mode=OneWayToSource}"/>
                                            </StackPanel>
                                        </Grid>
                                    </GroupBox>
                                </StackPanel>
                            </GroupBox>
                            
                            
                            <!--Core Colors-->
                            <GroupBox IsEnabled="{Binding ProjectDetails.parameters.numCylindersPerLayer, Converter={StaticResource CeilingLessOrEqualConverter}, ConverterParameter=5}">
                                <GroupBox.Header>
                                    <CheckBox Content="Core Color" IsEnabled="False" IsChecked="True"/>
                                </GroupBox.Header>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Color 1 -->
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="0"
Visibility="{Binding ProjectDetails.parameters.numCylindersPerLayer, Converter={StaticResource CeilingGreaterOrEqualConverter}, ConverterParameter=1}">
                                            <TextBlock Text="Color 1:" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="Color1ComboBox"
                                                      ItemsSource="{Binding ColorList}" Width="65" Margin="5 0 0 0" VerticalAlignment="Center"
  SelectedValue="{Binding ProjectDetails.parameters.condscreencolor1, Mode=OneWayToSource}"/>
                                        </StackPanel>
                                        <!-- Color 2 -->
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1"
Visibility="{Binding ProjectDetails.parameters.numCylindersPerLayer, Converter={StaticResource CeilingGreaterOrEqualConverter}, ConverterParameter=2}">
                                            <TextBlock Text="Color 2:" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="Color2ComboBox"
                                                      ItemsSource="{Binding ColorList}" Width="65" Margin="5 0 0 0" VerticalAlignment="Center"
  SelectedValue="{Binding ProjectDetails.parameters.condscreencolor2, Mode=OneWayToSource}"/>
                                        </StackPanel>
                                        <!-- Color 3 -->
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="2"
Visibility="{Binding ProjectDetails.parameters.numCylindersPerLayer, Converter={StaticResource CeilingGreaterOrEqualConverter}, ConverterParameter=3}">
                                            <TextBlock Text="Color 3:" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="Color3ComboBox"
                                                      ItemsSource="{Binding ColorList}" Width="65" Margin="5 0 0 0" VerticalAlignment="Center"
  SelectedValue="{Binding ProjectDetails.parameters.condscreencolor3, Mode=OneWayToSource}"/>
                                        </StackPanel>
                                        <!-- Color 4 -->
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="3"
Visibility="{Binding ProjectDetails.parameters.numCylindersPerLayer, Converter={StaticResource CeilingGreaterOrEqualConverter}, ConverterParameter=4}">
                                            <TextBlock Text="Color 4:" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="Color4ComboBox"
                                                      ItemsSource="{Binding ColorList}" Width="65" Margin="5 0 0 0" VerticalAlignment="Center"
  SelectedValue="{Binding ProjectDetails.parameters.condscreencolor4, Mode=OneWayToSource}"/>
                                        </StackPanel>
                                        <!-- Color 5 -->
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="4"
Visibility="{Binding ProjectDetails.parameters.numCylindersPerLayer, Converter={StaticResource CeilingGreaterOrEqualConverter}, ConverterParameter=5}">
                                            <TextBlock Text="Color 5:" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="Color5ComboBox"
                                                ItemsSource="{Binding ColorList}" Width="65" Margin="5 0 0 0" VerticalAlignment="Center"
  SelectedValue="{Binding ProjectDetails.parameters.condscreencolor5, Mode=OneWayToSource}"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    
                                    <Grid Grid.Column="1">
                                        <Grid.IsEnabled>
                                            <Binding Path="ProjectDetails.parameters.numCylindersPerLayer" Converter="{StaticResource DecimalValueConverter}"/>
                                        </Grid.IsEnabled>
                                        <StackPanel Orientation="Horizontal" Margin="5" >
                                            <TextBlock Text="Half Core Color :" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="Color6ComboBox" ItemsSource="{Binding ColorList}" Width="65" Margin="5 0 0 0" VerticalAlignment="Center"
              SelectedValue="{Binding ProjectDetails.parameters.halfcondscreencolor, Mode=OneWayToSource}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>


                            <!-- Identification GroupBox indicating the feature will be available later -->
                            <!--<GroupBox Height="100"
                                IsEnabled="False" ToolTip="This feature will be available in future version.">
                                <GroupBox.Header>
                                    <CheckBox Content="Identification" IsEnabled="False"/>
                                </GroupBox.Header>
                                <Grid>
                                    <TextBlock Text="This feature will be unveiled in upcoming version." 
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Center" 
                                               Foreground="Gray"/>
                                </Grid>
                            </GroupBox>-->




                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border BorderBrush="Gray" Grid.Row="1"  Grid.Column="1" BorderThickness="1" Padding="1">

                    <StackPanel Margin="10" IsEnabled="{Binding CableInfoPanelEnabled}">
                        <!--Filler-->
                        <GroupBox Visibility="{Binding SelectedCableCoreType, Converter={StaticResource CoreTypeVisibilityConverter}}">
                            <GroupBox.Header>
                                <CheckBox Content="Filler" IsChecked="{Binding IsFillerEnable, Mode=TwoWay}"/>
                            </GroupBox.Header>
                            <StackPanel IsEnabled="{Binding IsFillerEnable}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                        <TextBlock Text="Filling Method :" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="FillingMethodList" 
                                                ItemsSource="{Binding FillingMethodList}"
                                                SelectedItem="{Binding ProjectDetails.parameters.FillingMethod, UpdateSourceTrigger=PropertyChanged}"
                                                Margin="10 0 0 0" Width="100" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center" Grid.Column="1">
                                        <TextBlock Text="Number of Filler :" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="NumberOfFillerItem" 
                                                    ItemsSource="{Binding NoOfFillerList}" 
                                                    SelectedItem="{Binding ProjectDetails.parameters.SelectedNumberOfFillers, UpdateSourceTrigger=PropertyChanged}"
                                                    IsEnabled="{Binding ProjectDetails.parameters.FillingMethod, 
                                                                 Converter={StaticResource FillingMethodConverter}}"
                                                    Margin="10 0 0 0" 
                                                    Width="100" 
                                                    VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <GroupBox Header="Manual Fillers Thickness [mm]">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment ="Center" Margin="5">
                                            <TextBlock Text="Filler 1 : "/>
                                            <TextBox x:Name="Filler1TextBox"
                                                       IsEnabled="{Binding ProjectDetails.parameters.SelectedNumberOfFillers, Converter={StaticResource LayerVisibilityConverter}, ConverterParameter=1}"
                                                       Text="{Binding ProjectDetails.parameters.Filler1, UpdateSourceTrigger=PropertyChanged}"
                                                       Width="100" Margin="5 0 0 0" HorizontalContentAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment ="Center" Margin="5" Grid.Column="1">
                                            <TextBlock Text="Filler 2 : "/>
                                            <TextBox x:Name="Filler2TextBox" 
                                                   IsEnabled="{Binding ProjectDetails.parameters.SelectedNumberOfFillers, Converter={StaticResource LayerVisibilityConverter}, ConverterParameter=2}"                                                     
                                                   Text="{Binding ProjectDetails.parameters.Filler2, UpdateSourceTrigger=PropertyChanged}"
                                                   Width="100" Margin="5 0 0 0" HorizontalContentAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment ="Center" Margin="5" Grid.Column="2">
                                            <TextBlock Text="Filler 3 : "/>
                                            <TextBox x:Name="Filler3TextBox" 
                                                   IsEnabled="{Binding ProjectDetails.parameters.SelectedNumberOfFillers, Converter={StaticResource LayerVisibilityConverter}, ConverterParameter=3}"                                                     
                                                   Text="{Binding ProjectDetails.parameters.Filler3, UpdateSourceTrigger=PropertyChanged}"
                                                   Width="100" Margin="5 0 0 0" HorizontalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </GroupBox>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Filler Material : " Margin="5" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="FillerMaterialList" 
                                            ItemsSource="{Binding FillerMaterialList}"
                                            SelectedItem="{Binding ProjectDetails.parameters.FillerMaterial}"
                                            Width="200" Margin="5" VerticalContentAlignment="Center"
                                           SelectedValue="{Binding ProjectDetails.parameters.FillerMaterial}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>


                        <!--Laying OD-->
                        <!--
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Laying up OD [mm] :" Margin="10 5 10 5"/>
                            <TextBox x:Name="LayingUpODText"
                                     Text="{Binding ProjectDetails.parameters.LayingUpOD,ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                     Width="150" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Center"
                                     IsEnabled="False"/>
                        </StackPanel>-->

                        <!--<GroupBox Header="Sectoral Shaped">
                            <Grid>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                        <TextBlock Text="Fillet Radius [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="filletRadTextBox" 
                                              Text="{Binding ProjectDetails.parameters.fillet_radius, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                    </StackPanel>
                                    -->
                        <!--<StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center" Grid.Column="1">
                                        <TextBlock Text="Conductor screen Dia [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="conductorTextBox" 
                                            Text="{Binding ProjectDetails.parameters.preinnersheaththickness, UpdateSourceTrigger=PropertyChanged}"
                                            Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                    </StackPanel>-->
                        <!--
                                </StackPanel>
                            </Grid>
                        </GroupBox>-->


                        <!--Insulation screen-->
                        <GroupBox>
                            <GroupBox.Header>
                                <CheckBox Content="Screening" IsChecked="{Binding IsInsulationScreenEnable, Mode=TwoWay}"/>
                            </GroupBox.Header>
                            <Grid IsEnabled="{Binding IsInsulationScreenEnable}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                    <TextBlock Text="Screening Thickness [mm] :" VerticalAlignment="Center"/>
                                    <TextBox x:Name="InsulationScreenThkTextBox" 
                                             Text="{Binding ProjectDetails.parameters.preinnersheaththickness, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                             Margin="10 0 0 0" Width="90" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="InsulationScreenMaterialList" 
                                              ItemsSource="{Binding InsulationScreenMaterialList}"
                                              Margin="10 0 0 0" Width="90" VerticalContentAlignment="Center"
                                              SelectedValue="{Binding ProjectDetails.parameters.insulationScreenMaterial}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="Color : " Margin="0" VerticalAlignment="Center"/>
                                    <ComboBox 
                            ItemsSource="{Binding ColorList}"
                            Width="80" Margin="5 0"
                            SelectedValue="{Binding ProjectDetails.parameters.preinnersheathcolor, Mode=OneWayToSource}"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!--Inner Sheath-->
                        <GroupBox>
                            <GroupBox.Header>
                                <CheckBox Content="Inner Sheath" IsChecked="{Binding IsInnerSheathEnable, Mode=TwoWay}"/>
                            </GroupBox.Header>
                            <StackPanel IsEnabled="{Binding IsInnerSheathEnable}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="250"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                        <TextBlock Text="Inner Sheath Thickness [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="InnerSheathThkTextBox"
                                                 Text="{Binding ProjectDetails.parameters.innersheaththickness, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                 Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="InnerSheathMaterialList" 
                                                  ItemsSource="{Binding InnerSheathMaterialList}"
                                                  Margin="10 0 0 0" Width="150" VerticalContentAlignment="Center"
                                                  SelectedValue="{Binding ProjectDetails.parameters.innerSheathMaterial}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Inner Sheath Color : " Margin="5" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="InnerSheathColorItem" 
                                              ItemsSource="{Binding ColorList}"
                                              Width="100" Margin="5"
                                             SelectedValue="{Binding ProjectDetails.parameters.innersheathcolor, Mode=OneWayToSource}"/>
                                </StackPanel>

                                <CheckBox Content="Insualtion over Inner Sheath" IsChecked="{Binding IsoverinnersheaththicknessEnable}" Margin="5" Grid.Column="1" VerticalAlignment="Center"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                    <TextBlock Text="Over Inner Sheath Thickness [mm] :" VerticalAlignment="Center"/>
                                    <TextBox x:Name="overinnersheaththickness"
                                             IsEnabled="{Binding IsoverinnersheaththicknessEnable}" 
                                             Text="{Binding ProjectDetails.parameters.overinnersheaththickness, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                             Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Color : " Margin="0" VerticalAlignment="Center"/>
                                        <ComboBox 
                                                ItemsSource="{Binding ColorList}"
                                                Width="80" Margin="5 0"
                                                IsEnabled="{Binding IsoverinnersheaththicknessEnable}"
                                                SelectedValue="{Binding ProjectDetails.parameters.overinnersheathcolor, Mode=OneWayToSource}"/>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </GroupBox>

                        <!--Armouring-->
                        <GroupBox>
                            <GroupBox.Header>
                                <CheckBox Content="Armouring" IsChecked="{Binding IsArmoringEnable, Mode=TwoWay}"/>
                            </GroupBox.Header>
                            <StackPanel>
                                <Grid IsEnabled="{Binding IsArmoringEnable}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Armour Type :" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="ArmouringTypeItem" 
                                                  SelectedItem="{Binding ProjectDetails.parameters.armor_choice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding ArmorTypeList}"                                                  
                                                  Margin="10 0 0 0" Width="150" VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center" Visibility="Hidden">
                                        <TextBlock Text="Armor Color : " Margin="0" VerticalAlignment="Center"/>
                                        <ComboBox 
                                            ItemsSource="{Binding ColorList}"
                                            Width="100" Margin="5 0"
                                           SelectedValue="{Binding ProjectDetails.parameters.armorcolor, Mode=OneWayToSource}" />
                                    </StackPanel>
                                </Grid>
                                <Grid IsEnabled="{Binding IsArmoringEnable}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center" Grid.Column="0"  IsEnabled="{Binding ProjectDetails.parameters.IsWireArmor}">
                                        <TextBlock Text="Wire Dia [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="ArmorSizeTextBox" 
                                                  Text="{Binding ProjectDetails.parameters.cylinder_dia, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                  Margin="10 0 0 0" Width="80" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center"  Grid.Column="1" IsEnabled="{Binding ProjectDetails.parameters.IsCubicalArmor}">
                                        <TextBlock Text="Side Length [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="SideLengthTextBox" 
                                             Text="{Binding ProjectDetails.parameters.side_length, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                             Margin="10 0 0 0" Width="50" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center" Grid.Column="2" IsEnabled="{Binding ProjectDetails.parameters.IsCubicalArmor}">
                                        <TextBlock Text="Side Thickness [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="SideThkTextBox" 
                                                 Text="{Binding ProjectDetails.parameters.side_thickness, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                 Margin="10 0 0 0" Width="50" TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                
                            </StackPanel>
                        </GroupBox>

                        <!--Armor tapping-->
                        <GroupBox>
                            <GroupBox.Header>
                                <CheckBox Content="Taping" IsChecked="{Binding IsTapingEnabled, Mode=TwoWay}"/>
                            </GroupBox.Header>
                            <Grid IsEnabled="{Binding IsTapingEnabled}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                    <TextBlock Text="Taping Thickness [mm] :" VerticalAlignment="Center"/>
                                    <TextBox x:Name="TapingTextBox" 
                                             Text="{Binding ProjectDetails.parameters.armortapingthickness, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=1000}"
                                            Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Taping Color : " Margin="0" VerticalAlignment="Center"/>
                                    <ComboBox 
                            ItemsSource="{Binding ColorList}"
                            Width="100" Margin="5 0"
                            SelectedValue="{Binding ProjectDetails.parameters.armortapingcolor, Mode=OneWayToSource}"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>


                        <!--Outer Sheath-->
                        <GroupBox>
                            <GroupBox.Header>
                                <CheckBox Content="Outer Sheath" IsChecked="{Binding IsOuterSheathEnable, Mode=TwoWay}"/>
                            </GroupBox.Header>
                            <StackPanel IsEnabled="{Binding IsOuterSheathEnable}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="250"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                        <TextBlock Text="Outer Sheath Thickness [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="OuterSheathThkTextBox" 
                                                 Text="{Binding ProjectDetails.parameters.outersheaththickness,UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Delay=2000}"
                                                 Margin="10 0 0 0" Width="100" TextAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="5" Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Material :" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="OuterSheathMaterialList"
                                                  ItemsSource="{Binding OuterSheathMaterialList}"
                                                  Margin="10 0 0 0" Width="150" VerticalContentAlignment="Center"
                                                  SelectedValue="{Binding ProjectDetails.parameters.outerSheathMaterial}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Outer Sheath Color : " Margin="5" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="OuterSheathColorItem"
                                                  ItemsSource="{Binding ColorList}"
                                                  Width="100" Margin="5"
                                                  SelectedValue="{Binding ProjectDetails.parameters.outersheathcolor, Mode=OneWayToSource}"/>
                                    </StackPanel>
                                    <!--<CheckBox Content="Insulation over Outer Sheath" Margin="5" Grid.Column="1" VerticalAlignment="Center" IsEnabled="False"/>-->
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox 
                                            Content="Require Outer Sheath Line" 
                                            IsChecked="{Binding ProjectDetails.parameters.outersheathLineRequired}" 
                                            Margin="5" 
                                            Grid.Column="0" 
                                            VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Grid.Column="1">
                                        <TextBlock 
                                                Text=" Outer Sheath Line Color : " 
                                                Margin="5" 
                                                VerticalAlignment="Center"/>
                                        <ComboBox
                                                ItemsSource="{Binding ColorList}"
                                                Width="100" 
                                                Margin="5"
                                                SelectedValue="{Binding ProjectDetails.parameters.outercolor1, Mode=OneWayToSource}"
                                                IsEnabled="{Binding ProjectDetails.parameters.outersheathLineRequired}">
                                            <!-- Clear the selection when CheckBox is unchecked -->
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox">
                                                    <Style.Triggers>
                                                        <DataTrigger 
                                                            Binding="{Binding ProjectDetails.parameters.outersheathLineRequired}" 
                                                            Value="False">
                                                            <Setter Property="SelectedValue" Value="{x:Null}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!--Cable OD & Printing Matter-->
                        <StackPanel Orientation="Horizontal">
                            <Grid>
                                <StackPanel>
                                    <!-- StackPanel for Cable OD -->
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                                        <TextBlock Text="Calculated Cable OD [mm] :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="CableODTextBox" Margin="10 0 0 0" Width="100" TextAlignment="Center"
                                                 Text="{Binding ProjectDetails.parameters.leftoverDia}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <!-- StackPanel for Printing Matter -->
                                    <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center" Grid.Column="1">
                                        <TextBlock Text="Printing Matter :" VerticalAlignment="Center"/>
                                        <TextBox x:Name="PrintingMatterTextBox" Margin="10 0 0 0" Width="160" 
                                                 Text="{Binding ProjectDetails.parameters.printingMatter}"
                                                 MaxLength="60"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Button Content="Generate cable" 
                                Command="{Binding GenerateCommand}" 
                                Height="30" Width="150"    
                                FontSize="14"
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Margin="5"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!--Status Bar-->
            <Grid Background="White" HorizontalAlignment="Left" Height="20" Grid.Row="2">
                <StackPanel x:Name="LodingWheel" Orientation="Horizontal">
                    <Viewbox Height="18" Width="18" Stretch="Fill" Margin="5 0 0 0" Visibility="{Binding LodingWheelVisibility}">
                        <Path Stretch="Fill" Stroke="Black" StrokeThickness="8" Fill="Transparent" Data="M 50,10 A 40,40 0 1 1 90.45,29.55" RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform/>
                            </Path.RenderTransform>
                            <Path.Style>
                                <Style>
                                    <Style.Triggers>
                                        <Trigger Property="Path.IsEnabled" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" TextAlignment="Center" Margin="10 0 0 0" Foreground="Gray" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
